    "@mui/material": "^5.16.7",
    "@mui/x-date-pickers": "^7.22.1",
    "date-fns": "^3.6.0",
    "dexie": "^4.0.8",
    "i18next": "^23.16.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "react-i18next": "^15.1.0",
    "react-router-dom": "^6.27.0",
