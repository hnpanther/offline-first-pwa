# Copy to .env.mobile before npm run build:mobile
#
# Production (nginx on 192.168.1.4, API proxied to 192.168.1.2:8081):
#   VITE_SERVER_URL=https://192.168.1.4
#
# Local dev preview (Vite on :4173):
#   VITE_SERVER_URL=https://<your-pc-lan-ip>:4173
#
# Must match the URL tablets open in the browser — NOT the Spring host/port.
VITE_SERVER_URL=https://192.168.1.4
